# ── Servidor ───────────────────────────────────────────────
PORT=3000

# ── Base de datos (Turso / libSQL) ─────────────────────────
TURSO_URL=libsql://tu-base.turso.io
TURSO_TOKEN=

# ── Auth ───────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
HASH_SALT=10

# ── Email (MailerSend) ─────────────────────────────────────
MAILERSEND_TOKEN=

# ── CORS ───────────────────────────────────────────────────
# Arrays JSON con los orígenes permitidos (origin del FRONT, sin barra final).
# HOST se usa en producción; LOCALHOST_IP en desarrollo.
# Demo: HOST=["https://peko.santiagomustafa.com.ar"]
HOST=["https://tu-dominio.com"]
LOCALHOST_IP=["http://localhost:5173"]

# ── MercadoPago ────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── URLs públicas (callbacks de pago y webhooks) ───────────
# PUBLIC_API_URL: base pública de la API (sin /api/v1, se agrega solo).
# PUBLIC_WEB_URL: base del frontend para los redirects de pago.
# Demo: PUBLIC_API_URL=https://api.santiagomustafa.com.ar
#       PUBLIC_WEB_URL=https://peko.santiagomustafa.com.ar
PUBLIC_API_URL=http://localhost:3000
PUBLIC_WEB_URL=http://localhost:5173
