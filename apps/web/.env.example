# URL base de la API (incluye el prefijo /api/v1)
# Producción/demo (API en Render, mismo dominio raíz que la web):
#   VITE_HOST=https://api.peko.santiagomustafa.com.ar/api/v1
VITE_HOST=http://localhost:3000/api/v1

# Clave pública de MercadoPago (Public Key del SDK del navegador)
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
